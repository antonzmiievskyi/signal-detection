{
  "name": "signal-detection",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerUser": "dev",
  "containerEnv": {
    "PYTHONUNBUFFERED": "1"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
