{
  "name": "signal-detection",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerUser": "dev",
  "containerEnv": {
    "PYTHONUNBUFFERED": "1"
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/dev/.claude,type=bind,consistency=delegated"
  ],
  "remoteEnv": {
    "CLAUDE_CONFIG_DIR": "/home/dev/.claude"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
